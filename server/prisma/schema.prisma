generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 1. Управління користувачами та ролями
// ==========================================

model Role {
  id        String     @id @default(uuid())
  name      String     @unique
  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model User {
  id                   String    @id @default(uuid())
  schoolId             String?
  email                String    @unique
  password             String
  firstName            String
  middleName           String?
  lastName             String
  avatarUrl            String?   @default("https://spark-school-system-bucket.s3.eu-central-1.amazonaws.com/assets/default-avatar.svg")
  createdAt            DateTime  @default(now())
  isEmailVerified      Boolean   @default(false)
  isPasswordCustom     Boolean   @default(false)
  lastLoginAt          DateTime?
  parentsCode          String?   @unique
  themePreference      String?   @default("light")
  commentsBlockedUntil DateTime?

  // Зв'язки: Базові
  school         School?    @relation("SchoolUsers", fields: [schoolId], references: [id])
  directedSchool School?    @relation("SchoolDirector")
  userRoles      UserRole[]

  // Зв'язки: Батьки та діти (Самореференція)
  parentRelations  StudentParent[] @relation("ParentRelation")
  studentRelations StudentParent[] @relation("StudentRelation")

  // Зв'язки: Навчальний процес
  homeroomClass   Class?           @relation("HomeroomTeacher")
  studentClasses  ClassStudent[]
  teacherSubjects TeacherSubject[]

  createdCourses  Course[]        @relation("CourseCreator")
  coTaughtCourses CourseTeacher[]
  enrolledCourses CourseStudent[]

  // Зв'язки: Контент та оцінки
  announcements   Announcement[]
  materials       Material[]
  tasks           Task[]
  tests           Test[]
  submissions     Submission[]
  writtenComments Comment[]      @relation("CommentAuthor")
  targetComments  Comment[]      @relation("CommentTarget")
  givenGrades     Gradebook[]    @relation("TeacherGrades")
  receivedGrades  Gradebook[]    @relation("StudentGrades")
  attendances     Attendance[]

  // Зв'язки: Комунікація
  sentNotifications     Notification[]     @relation("SentNotifications")
  receivedNotifications Notification[]     @relation("ReceivedNotifications")
  madeComplaints        Complaint[]        @relation("ReporterRelation")
  receivedComplaints    Complaint[]        @relation("ReportedRelation")
  readAnnouncements     AnnouncementRead[]

  @@map("users")
}

model StudentParent {
  studentId String
  parentId  String

  student User @relation("StudentRelation", fields: [studentId], references: [id], onDelete: Cascade)
  parent  User @relation("ParentRelation", fields: [parentId], references: [id], onDelete: Cascade)

  @@id([studentId, parentId])
  @@map("student_parents")
}

// ==========================================
// 2. Структура навчального закладу
// ==========================================

model School {
  id         String  @id @default(uuid())
  directorId String? @unique
  edrpou     String? @unique

  fullName         String
  shortName        String?
  region           String?
  city             String?
  address          String?
  phone            String?
  email            String?
  website          String?
  directorFullName String?

  isVerified Boolean @default(false)

  director User?    @relation("SchoolDirector", fields: [directorId], references: [id])
  users    User[]   @relation("SchoolUsers")
  classes  Class[]
  courses  Course[]

  @@map("schools")
}

model Class {
  id                String  @id @default(uuid())
  schoolId          String
  homeroomTeacherId String? @unique
  name              String

  school          School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  homeroomTeacher User?          @relation("HomeroomTeacher", fields: [homeroomTeacherId], references: [id])
  students        ClassStudent[]
  courses         Course[]

  @@map("classes")
}

model ClassStudent {
  classId   String
  studentId String

  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([classId, studentId])
  @@map("class_students")
}

model Subject {
  id   String @id @default(uuid())
  name String @unique

  teachers  TeacherSubject[]
  nusGroups NusGroup[]
  courses   Course[]

  @@map("subjects")
}

model TeacherSubject {
  teacherId String
  subjectId String

  teacher User    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([teacherId, subjectId])
  @@map("teacher_subjects")
}

model NusGroup {
  id        String @id @default(uuid())
  subjectId String
  name      String

  subject Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  tasks   Task[]
  tests   Test[]
  grades  Gradebook[]

  @@map("nus_groups")
}

// ==========================================
// 3. Навчальні курси
// ==========================================

model Course {
  id            String   @id @default(uuid())
  schoolId      String
  subjectId     String
  classId       String
  creatorId     String
  startDate     DateTime @default(now())
  endDate       DateTime @default(now())
  groupName     String?
  isArchived    Boolean  @default(false)
  isHidden      Boolean  @default(false)
  themeColor    String?  @default("#702DFF")
  backgroundUrl String?
  videoLinks    String[]

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  creator User    @relation("CourseCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  coTeachers CourseTeacher[]
  students   CourseStudent[]

  modules       CourseModule[]
  announcements Announcement[]
  materials     Material[]
  tasks         Task[]
  tests         Test[]
  gradebooks    Gradebook[]
  attendances   Attendance[]

  @@map("courses")
}

model CourseModule {
  id        String   @id @default(uuid())
  courseId  String
  title     String
  createdAt DateTime @default(now())

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials Material[]
  tasks     Task[]
  tests     Test[]

  @@map("course_modules")
}

model CourseTeacher {
  courseId  String
  teacherId String

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@id([courseId, teacherId])
  @@map("course_teachers")
}

model CourseStudent {
  courseId  String
  studentId String

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([courseId, studentId])
  @@map("course_students")
}

// ==========================================
// 4. Навчальний процес та контент
// ==========================================

model Announcement {
  id        String   @id @default(uuid())
  courseId  String
  creatorId String
  title     String
  content   String
  createdAt DateTime @default(now())

  course  Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  creator User               @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  reads   AnnouncementRead[]

  @@map("announcements")
}

model AnnouncementRead {
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId])
  @@map("announcement_reads")
}

model Material {
  id             String   @id @default(uuid())
  courseId       String
  creatorId      String
  courseModuleId String?
  title          String
  fileUrl        String?
  linkUrl        String?
  createdAt      DateTime @default(now())
  isHidden       Boolean  @default(false)

  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  creator      User          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  courseModule CourseModule? @relation(fields: [courseModuleId], references: [id], onDelete: SetNull)

  @@map("materials")
}

model Task {
  id             String    @id @default(uuid())
  courseId       String
  creatorId      String
  nusGroupId     String?
  courseModuleId String?
  title          String
  description    String?
  deadline       DateTime?
  createdAt      DateTime  @default(now())
  isHidden       Boolean   @default(false)
  attachments    String[]

  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  creator      User          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  nusGroup     NusGroup?     @relation(fields: [nusGroupId], references: [id], onDelete: SetNull)
  courseModule CourseModule? @relation(fields: [courseModuleId], references: [id], onDelete: SetNull)
  submissions  Submission[]
  gradebooks   Gradebook[]
  comments     Comment[]

  @@map("tasks")
}

model Test {
  id                   String    @id @default(uuid())
  courseId             String
  creatorId            String
  nusGroupId           String?
  courseModuleId       String?
  title                String
  timeLimitMinutes     Int?
  deadline             DateTime?
  maxAttempts          Int       @default(1)
  isResultHidden       Boolean   @default(false)
  isAttemptHidden      Boolean   @default(false)
  isShowCorrectAnswers Boolean   @default(true)
  isShuffleQuestions   Boolean   @default(false)
  isShuffleAnswers     Boolean   @default(false)
  isHidden             Boolean   @default(false)
  createdAt            DateTime  @default(now())

  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  creator      User          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  nusGroup     NusGroup?     @relation(fields: [nusGroupId], references: [id], onDelete: SetNull)
  courseModule CourseModule? @relation(fields: [courseModuleId], references: [id], onDelete: SetNull)
  questions    Question[]
  submissions  Submission[]
  gradebooks   Gradebook[]
  comments     Comment[]

  @@map("tests")
}

model Question {
  id      String @id @default(uuid())
  testId  String
  type    String
  content String
  points  Float

  test             Test               @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers          Answer[]
  SubmissionAnswer SubmissionAnswer[]

  @@map("questions")
}

model Answer {
  id         String  @id @default(uuid())
  questionId String
  content    String
  isCorrect  Boolean @default(false)

  question         Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  SubmissionAnswer SubmissionAnswer[]

  @@map("answers")
}

model Submission {
  id          String    @id @default(uuid())
  taskId      String?
  testId      String?
  studentId   String
  submittedAt DateTime  @default(now())
  checkedAt   DateTime?
  score       String?
  duration    Int?
  attachments String[]

  task        Task?              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  test        Test?              @relation(fields: [testId], references: [id], onDelete: Cascade)
  student     User               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  testAnswers SubmissionAnswer[]

  @@map("submissions")
}

model SubmissionAnswer {
  id           String @id @default(uuid())
  submissionId String
  questionId   String
  answerId     String

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer     Answer     @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@map("submission_answers")
}

model Comment {
  id              String   @id @default(uuid())
  authorId        String
  targetStudentId String
  content         String
  createdAt       DateTime @default(now())
  taskId          String?
  testId          String?

  author        User        @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetStudent User        @relation("CommentTarget", fields: [targetStudentId], references: [id], onDelete: Cascade)
  task          Task?       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  test          Test?       @relation(fields: [testId], references: [id], onDelete: Cascade)
  complaints    Complaint[]

  @@map("comments")
}

// ==========================================
// 5. Оцінювання та облік
// ==========================================

model Gradebook {
  id         String   @id @default(uuid())
  studentId  String
  teacherId  String
  courseId   String
  taskId     String?
  testId     String?
  nusGroupId String?
  gradeType  String // "VERBAL", "LEVEL", "NUS", "TRADITIONAL"
  date       DateTime @default(now())
  score      Float?

  student  User      @relation("StudentGrades", fields: [studentId], references: [id], onDelete: Cascade)
  teacher  User      @relation("TeacherGrades", fields: [teacherId], references: [id], onDelete: Cascade)
  course   Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  task     Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  test     Test?     @relation(fields: [testId], references: [id], onDelete: Cascade)
  nusGroup NusGroup? @relation(fields: [nusGroupId], references: [id], onDelete: SetNull)

  @@map("gradebooks")
}

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  courseId  String
  date      DateTime @default(now())
  status    String

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("attendances")
}

// ==========================================
// 6. Нотифікації та скарги
// ==========================================

model Notification {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  title      String
  content    String
  type       String
  isRead     Boolean  @default(false)
  metadata   Json?
  createdAt  DateTime @default(now())

  sender   User @relation("SentNotifications", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedNotifications", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Complaint {
  id             String   @id @default(uuid())
  reporterId     String
  reportedUserId String
  commentId      String?
  reason         String
  status         String   @default("PENDING") // "PENDING", "RESOLVED" (Схвалено), "REJECTED" (Відхилено), "BLOCKED" (Заблоковано)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  reporter     User     @relation("ReporterRelation", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User     @relation("ReportedRelation", fields: [reportedUserId], references: [id], onDelete: Cascade)
  comment      Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade) // <--- ДОДАТИ ЗВ'ЯЗОК

  @@map("complaints")
}

// ==========================================
// 7. Реєстр ЄДЕБО (Локальне дзеркало)
// ==========================================

model EdeboSchool {
  id                  String  @id @default(uuid())
  edeboId             String  @unique // Код в ЄДЕБО
  fullName            String // Повна назва
  shortName           String? // Скорочена назва
  isChecked           String? // ОУО підтвердив дані (так/ні)
  status              String? // Статус (напр., "працює")
  institutionType     String? // Тип закладу (гімназія, ліцей тощо)
  financingType       String? // Форма власності (Комунальна, Приватна)
  koatuuId            String? // Код КОАТУУ
  region              String // Регіон
  koatuuName          String? // Населений пункт (за КОАТУУ)
  address             String? // Місцезнаходження (юридична адреса)
  katottgCode         String? // Код КАТОТТГ
  katottgName         String? // Населений пункт (за КАТОТТГ)
  parentInstitutionId String? // Головний заклад (ID, якщо це філія)
  governanceName      String? // Найменування органу, до сфери управління якого належить
  phone               String? // Телефон
  fax                 String? // Факс
  email               String? // Електронна пошта
  website             String? // Веб-сайт
  directorFullName    String? // Керівник (Посада + ПІБ)
  isSupport           String? // Опорний / Філія (так/ні)
  isVillage           String? // Сільський (так/ні)
  isMountain          String? // Гірський (так/ні)
  isInternat          String? // Інтернат (так/ні)
  approvedCount       String? // Ліцензовані обсяги

  // Наше допоміжне поле для зручного і швидкого пошуку в дропдауні:
  city String // Уніфікований населений пункт

  updatedAt DateTime @updatedAt

  @@index([region])
  @@index([city])
  @@map("edebo_schools")
}

// ==========================================
// 8. Заявки на реєстрацію (Модерація)
// ==========================================

model SchoolRegistrationRequest {
  id                     String   @id @default(uuid())
  edeboId                String
  email                  String
  passwordHash           String
  firstName              String
  lastName               String
  middleName             String?
  passportDocs           String[] // Паспорт громадянина України
  edrDocs                String[] // Витяг з ЄДР
  appointmentOrderDocs   String[] // Наказ про призначення
  employmentContractDocs String[] // Трудовий контракт
  status                 String   @default("PENDING")
  rejectionReason        String?
  createdAt              DateTime @default(now())

  @@map("school_registration_requests")
}
